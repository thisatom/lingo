{
  "include": [
    "electron.vite.config.ts",
    "electron/**/*",
    "src/shared/types/**/*",
    "src/shared/config/**/*",
    "src/shared/lib/web-search-intent.ts",
    "src/shared/lib/chat-message-api.ts",
    "src/entities/message/model/**/*",
    "src/shared/lib/openrouter-errors.ts",
    "src/shared/lib/openrouter-headers.ts",
    "src/shared/lib/openrouter-model.ts",
    "src/shared/lib/openrouter-chat-stream.ts",
    "src/shared/lib/html-to-text.ts",
    "src/shared/lib/local-page-research.ts",
    "src/shared/lib/local-web-search.ts",
    "src/shared/lib/websearch-config.ts",
    "src/shared/lib/websearch-crawler.ts",
    "src/shared/lib/websearch-mcp-client.ts",
    "src/shared/lib/websearch-query.ts",
    "src/shared/lib/local-search-city.ts",
    "src/shared/lib/local-search-intent.ts",
    "src/shared/lib/local-search-weather.ts",
    "src/shared/lib/local-search-time.ts",
    "src/shared/lib/local-web-search-runtime.ts",
    "src/shared/lib/setup-local-web-search.ts",
    "src/shared/lib/web-search-messages.ts",
    "src/shared/lib/image-ocr-runtime.ts",
    "src/shared/lib/image-ocr-messages.ts",
    "src/shared/lib/image-ocr-tesseract.ts",
    "src/shared/lib/strip-text-for-speech.ts",
    "src/shared/lib/prepare-text-for-speech.ts",
    "src/shared/lib/tts-rate.ts",
    "src/shared/config/tts-voices.ts",
    "src/shared/config/titlebar.ts",
    "src/shared/types/app-theme.ts",
    "src/shared/lib/theme.ts",
    "src/features/speech-to-text/lib/speech-audio-constants.ts",
    "src/features/speech-to-text/lib/wav-pcm.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
