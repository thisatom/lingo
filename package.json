{
  "name": "lingo",
  "version": "0.1.0",
  "description": "Practice conversational speech in different languages",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.config.ts",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux",
    "build:web": "vite build --config vite.config.ts",
    "preview": "electron-vite preview",
    "preview:web": "vite preview --config vite.config.ts",
    "postinstall": "node scripts/ensure-electron.mjs && electron-rebuild -f -w keytar",
    "electron:install": "node scripts/ensure-electron.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "icons:png": "python scripts/icon-ico-to-png.py"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@gsap/react": "^2.1.2",
    "@huggingface/transformers": "^4.2.0",
    "@incanta/custom-electron-titlebar": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.25",
    "@vscode/codicons": "^0.0.45",
    "ai": "^4.3.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "edge-tts-universal": "^1.3.3",
    "gsap": "^3.15.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "keytar": "^7.9.0",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.39.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.6.1",
    "react-speech-recognition": "^4.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tesseract.js": "^7.0.0",
    "undici": "^8.3.0",
    "websearch-mcp": "^1.0.3",
    "zod": "^3.25.28",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
